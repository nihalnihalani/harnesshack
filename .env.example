# Copy to .env and fill during the T+0 auth sprint (see CLAUDE.md Go/No-Go Gates).
# NEVER commit the real .env.

# Guild.ai (control plane) — T+0:00 gate, 15-min hard cap
GUILD_PAT=
GUILD_API_BASE=

# ClickHouse Cloud
CLICKHOUSE_HOST=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# Langfuse (observability — runs on ClickHouse) — T+0:20 gate
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Pioneer / Fastino (GLiNER2 + GLiGuard) — T+0:15 gate, record measured latency
PIONEER_API_KEY=

# Airbyte Agent Engine — T+0:05 gate, 20-min cap then MCP fallback
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=

# Senso.ai (knowledge base)
SENSO_API_KEY=

# Composio (Slack + Jira via managed OAuth) — T+0:10 gate, use session.link()
COMPOSIO_API_KEY=

# Anthropic (postmortem drafting only — small models first)
ANTHROPIC_API_KEY=

# Frontend (goes in apps/frontend/.env.local)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Webhook hardening (Phase 8) — optional locally, REQUIRED posture in prod.
# When set, POST /trigger and /incidents/* demand `Authorization: Bearer <token>`;
# when unset, the API logs a loud "webhook auth DISABLED" warning at startup.
WEBHOOK_AUTH_TOKEN=
# Per-IP token bucket on the POST endpoints (default 60).
RATE_LIMIT_PER_MINUTE=60
